@{
    
}
<tr>
    <td>@Model.FullName</td>
    <td>@Model.Id</td>
    <td>@Model.Book?.Title</td>
    <td>@Model.Gmail</td>
    <td>@Model.Password</td>
    <td>@Model.Permissions</td>
    <td>
        @if (ViewContext.RouteData.Values["action"]?.ToString() == "Index")
        {
            <a href="/User/DeleteBook/@Model.Id" class="btn primary btn-danger"> Delete</a>
            <a href="/User/UpdateBook/@Model.Id" class="btn primary btn-warning"> Update</a>
        }

    </td>

</tr>   