@{
    ViewData["Title"] = "";
}
@model List<Loan>


<div class="background-overlay"></div>

<div class="container mt-5 content-wrapper">
    <div class="page-header">
        <h1 class="text-center mb-2" style="color: aliceblue;">📖 Kitap Kiralama Sistemi</h1>
        <br /><br /><br />
    </div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card shadow-lg border-0 statistics-card mb-4">
                <div class="card-header text-white" style="background-color: #e46b00;opacity: 0.8;">
                    <h4 class="mb-0">
                        <span class="header-icon">📊</span> İstatistikler
                    </h4>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-4">
                            <div class="stat-box stat-active">
                                <h3 class="stat-number">3</h3>
                                <p class="stat-label">Aktif</p>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="stat-box stat-warning">
                                <h3 class="stat-number">1</h3>
                                <p class="stat-label">Yakında</p>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="stat-box stat-danger">
                                <h3 class="stat-number">1</h3>
                                <p class="stat-label">Gecikmiş</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-lg border-0 mb-5 table-card">
                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">
                        <span class="header-icon">📋</span> Aktif Kiralamalar
                    </h4>
                </div>
                <div class="card-body p-0 ">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="thead-light">
                                <tr>
                                    <th>Öğrenci</th>
                                    <th>Kitap</th>
                                    <th>Yazar</th>
                                    <th>İade Tarihi</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody id="loanTableBody">
                                @foreach(var loan in Model)
                                {
                                    <tr>
                                        <td>@loan.Student.FullName</td>
                                        <td>@loan.Book.Title </td>
                                        <td>@loan.Book.Author.Name</td>
                                        <td>@loan.ReturnDate.Day/@loan.ReturnDate.Month/@loan.ReturnDate.Year</td>
                                        <td>@loan.IsReturned</td>
                                    </tr>
                                }
