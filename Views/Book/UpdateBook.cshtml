@model LibraryMVC.Models.Book

<div class="row" style="margin-left: 33% ; margin-top:10%" >
    <div class="col-lg-6 mb-4">
        <div class="card shadow-lg border-0 form-card">
            <div class="card-header text-white" style="background-color: #e46b00; opacity:0.8;">
                <h4 class="mb-0">
                    <span class="header-icon">➕</span> Yeni Kitap Ekle
                </h4>
            </div>
            
            <div class="card-body">
                <form asp-action="UpdateBook" asp-controller="Book" method="post">
                    
                    <!-- Kitap Adı -->
                    <div class="form-group mb-4">
                        <label asp-for="Title" class="font-weight-bold">
                            📖 Kitap Adı <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title" class="form-control form-control-lg" value="@Model.Title" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>
                    <div class="form-group mb-4">
                        <label asp-for="BookId" class="font-weight-bold">
                            📖 Kitap Adı <span class="text-danger">*</span>
                        </label>
                        <input asp-for="BookId" class="form-control form-control-lg" value="@Model.BookId" type="hidden" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <!-- Yazar -->
                    <div class="form-group mb-4">
                        <label asp-for="Author" class="font-weight-bold">
                            ✍️ Yazar <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Author" class="form-control form-control-lg" value="@Model.Author" />
                        <span asp-validation-for="Author" class="text-danger"></span>
                    </div>

                    <!-- Yayın Yılı -->
                    <div class="form-group mb-4">
                        <label asp-for="Year" class="font-weight-bold">
                            📅 Yayın Yılı <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Year" class="form-control form-control-lg" value="@Model.Year"/>
                        <span asp-validation-for="Year" class="text-danger"></span>
                    </div>
                    <!-- Tür -->
                    <div class="form-check">
                        <input asp-for="Genre" class="form-check-input" type="hidden" name="Genre" value="@Model.Genre" />
                        @* <label class="form-check-label">📜 Klasik</label> *@
                    </div>

                    <div class="form-check">
                        <input asp-for="Genre" class="form-check-input" type="hidden" name="Genre" value="@Model.Genre" />
                        @* <label class="form-check-label">📕 Roman</label> *@
                    </div>

                    <div class="form-check">
                        <input asp-for="Genre" class="form-check-input" type="hidden" name="Genre" value="@Model.Genre" />
                        @* <label class="form-check-label">📘 Hikaye</label> *@
                    </div>
                    <button type="submit"  class="btn btn-success btn-lg btn-block">
                        ✅ Kitabı Kaydet
                    </button>

                </form>
            </div>
        </div>
    </div>
</div>
