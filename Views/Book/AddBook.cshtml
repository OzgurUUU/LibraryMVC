@model Book

<div class="row" style="margin-left: 33% ; margin-top:10%">
    <div class="col-lg-6 mb-4 mt-5">
        <div class="card shadow-lg border-0 form-card">
            <div class="card-header text-white" style="background-color: #e46b00; opacity:0.8;">
                <h4 class="mb-0">
                    <span class="header-icon">➕</span> Yeni Kitap Ekle
                </h4>
            </div>

            <div class="card-body">
                <form asp-action="AddBook" asp-controller="Book" method="post">

                    <div class="form-group mb-4">
                        <label asp-for="Title" class="font-weight-bold">
                            📖 Kitap Adı <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Title" class="form-control form-control-lg" placeholder="Örn: Masumiyet" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="AuthorId" class="font-weight-bold">
                            ✍️ Yazar <span class="text-danger">*</span>
                        </label>
                        <select asp-for="AuthorId" class="form-control form-control-lg" asp-items="ViewBag.Authors">
                            <option value="">-- Yazar Seçiniz --</option>
                        </select>
                        <span asp-validation-for="AuthorId" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Year" class="font-weight-bold">
                            📅 Yayın Yılı <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Year" class="form-control form-control-lg" />
                        <span asp-validation-for="Year" class="text-danger"></span>
                    </div>

                    <label class="font-weight-bold">📚 Tür</label>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="Genre" value="Klasik" />
                        <label class="form-check-label">📜 Klasik</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="Genre" value="Roman" />
                        <label class="form-check-label">📕 Roman</label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="Genre" value="Hikaye" />
                        <label class="form-check-label">📘 Hikaye</label>
                    </div>

                    <span asp-validation-for="Genre" class="text-danger"></span>

                    <button type="submit" class="btn btn-success btn-lg btn-block mt-4">
                        ✅ Kitabı Kaydet
                    </button>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}